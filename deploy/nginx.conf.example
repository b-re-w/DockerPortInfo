# ──────────────────────────────────────────────────────────────────
# DockerPortInfo 를 기존 nginx(HTTPS) 에 붙이는 설정 예시
#
# 기존 dolab-gpu.duckdns.org 의 443 server { } 블록 안에,
# 기존 `location / { proxy_pass http://127.0.0.1:8090; }` 와 나란히 아래를 추가하세요.
# (prefix /info/docker/ 가 / 보다 구체적이라 우선 매칭됩니다.)
#
# 핵심: proxy_pass 에 trailing slash 와 경로를 붙이지 않습니다.
#       그래야 원본 URI(/info/docker/...) 가 그대로 앱(13000)으로 전달됩니다.
#       앱이 모든 라우트를 /info/docker 아래에 두기 때문입니다
#       (DOCKERPORTINFO_BASE_PATH 와 반드시 일치).
# ──────────────────────────────────────────────────────────────────

# (선택) trailing slash 없는 /info/docker 접근을 정규화
location = /info/docker {
    return 301 /info/docker/;
}

location /info/docker/ {
    proxy_pass http://127.0.0.1:13000;

    proxy_http_version 1.1;
    proxy_set_header Host              $host;
    proxy_set_header X-Real-IP         $remote_addr;
    proxy_set_header X-Forwarded-For   $proxy_add_x_forwarded_for;
    proxy_set_header X-Forwarded-Proto $scheme;
    proxy_set_header X-Forwarded-Host  $host;

    proxy_read_timeout 86400;
    proxy_buffering off;
}

# 적용:
#   sudo nginx -t && sudo systemctl reload nginx
# 확인:
#   https://dolab-gpu.duckdns.org/info/docker/
